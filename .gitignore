# Calibration images (host on Google Drive)
calibration/images/
calibration/**/*.jpg
calibration/**/*.jpeg
calibration/**/*.png

# Corner-detection cache (regenerable temp artifact, can be large)
calibration/_corners_cache*.npz

# Keep the small undistortion sample (documentation asset for the report)
!calibration/undistort_sample.jpg

# Dataset: raw images, labels, splits (host on Google Drive) 
dataset/raw/
dataset/splits/
dataset/**/*.jpg
dataset/**/*.jpeg
dataset/**/*.png

# host full exports on Drive.
dataset/**/*.zip

# Trained model weights (host on Google Drive)
models/weights/
*.pt
*.pth
*.onnx
*.h5
*.ckpt
*.pkl

# Inference / measurement outputs (keep a few small samples only)
inference/outputs/
measurement/outputs/

